{
  "$schema": "https://opencode.ai/config.json",
  "providers": {
    "openai": {
      "models": {
        "gpt-5.6-sol-pro": {
          "variants": [
            {
              "id": "max-fast",
              "settings": {
                "reasoningEffort": "max",
                "reasoningSummary": "auto",
                "include": ["reasoning.encrypted_content"]
              },
              "body": {
                "service_tier": "priority"
              }
            }
          ]
        }
      }
    }
  },
  "agents": {
    "build": {
      "model": "openai/gpt-5.6-sol-fast#max"
    },
    "plan": {
      "model": "openai/gpt-5.6-sol-fast#max"
    },
    "general": {
      "model": "openai/gpt-5.6-sol-fast#max"
    },
    "explore": {
      "model": "openai/gpt-5.6-sol-fast#max"
    },
    "compaction": {
      "model": "openai/gpt-5.6-sol-fast#max"
    },
    "summary": {
      "model": "openai/gpt-5.6-sol-fast#max"
    },
    "title": {
      "model": "openai/gpt-5.6-sol-fast#low"
    }
  },
  "mcp": {
    "servers": {
      // "context7": {
      //   "type": "remote",
      //   "url": "https://mcp.context7.com/mcp",
      //   "headers": {
      //     "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      //   }
      // }
    }
  }
}
