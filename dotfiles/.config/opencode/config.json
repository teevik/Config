{
  "$schema": "https://opencode.ai/config.json",
  "theme": "catppuccin",

  "compaction": {
    "auto": false,
    "prune": true
  },

  "plugin": [
    // "oh-my-opencode",
    // "opencode-supermemory@latest",
    "@nick-vi/opencode-type-inject@latest",
    "@mohak34/opencode-notifier@latest",
    // "@plannotator/opencode@latest",
    "opencode-wakatime@latest",
    "@0xsero/open-queue"
    // "@mailshieldai/opencode-canvas@latest"
  ],

  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "excalidraw": {
      "type": "remote",
      "url": "https://api.excalidraw.com/api/v1/mcp",
      "enabled": false,
      "headers": {
        "Authorization": "Bearer {env:EXCALIDRAW_TOKEN}"
      }
    }
  },

  "agent": {
    "explore": {
      "model": "opencode/claude-sonnet-4-6"
    },
    "scout": {
      "model": "opencode/claude-sonnet-4-6"
    }
  },

  "lsp": {
    "tailwind": {
      "command": ["bun", "x", "tailwindcss-language-server", "--stdio"],
      "extensions": [".tsx"]
    }
  },

  "permission": {
    "bash": {
      "git commit": "ask",
      "git push": "ask"
    },
    "canvas_*": "allow",

    "external_directory": {
      "*": "ask",

      // Full access to temp files/directories
      "/tmp": "allow",
      "/tmp/**": "allow",
      "/var/tmp": "allow",
      "/var/tmp/**": "allow",

      // Skill bundles used by opencode
      "~/.agents/skills": "allow",
      "~/.agents/skills/**": "allow",
      "~/.claude/skills": "allow",
      "~/.claude/skills/**": "allow",

      // Safe to read
      "/usr/share/**": "allow",
      "/usr/local/share/**": "allow",
      "/var/log/**": "allow",

      // Read-only nix store
      "/nix/store/**": "allow",

      // Rust source code from cargo registry
      "~/.cargo/registry/**": "allow"
    }
  }
}
