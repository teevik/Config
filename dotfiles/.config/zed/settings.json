{
  "show_signature_help_after_edits": true,
  "auto_signature_help": false,
  "code_lens": "on",
  "show_edit_predictions": true,
  "focus_follows_mouse": {
    "enabled": true
  },
  "agent_servers": {
    "codex-acp": {
      "default_config_options": {
        "fast-mode": true
      },
      "type": "registry"
    }
  },
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "diff_view_style": "unified",
  "agent": {
    "play_sound_when_agent_done": "always",
    "default_profile": "ask",
    "dock": "right",
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6",
      "enable_thinking": true,
      "effort": "high"
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "edit_predictions": {
    "mode": "subtle"
  },
  "git_panel": {
    "dock": "left",
    "tree_view": true
  },
  "session": {
    "trust_all_worktrees": true
  },
  "load_direnv": "direct",
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "theme": "Catppuccin Macchiato",

  // Editor settings (from nvim config)
  "vim_mode": true,
  "relative_line_numbers": "enabled",
  "tab_size": 2,
  "preferred_line_length": 80,
  "current_line_highlight": "all",
  "cursor_blink": false,
  "extend_comment_on_newline": false,
  "format_on_save": "on",
  "show_whitespaces": "boundary",
  "inlay_hints": {
    "show_other_hints": true,
    "show_parameter_hints": true,
    "show_type_hints": true,
    "show_value_hints": true,
    "show_background": false,
    "enabled": true
  },

  "vim": {
    "use_system_clipboard": "never"
  },

  "languages": {
    "Odin": {
      "format_on_save": "on",
      "formatter": "language_server",
      "semantic_tokens": "combined"
    },
    "Typst": {
      "soft_wrap": "bounded",
      "show_wrap_guides": false,
      "formatter": "language_server"
    },
    "Lua": {
      "tab_size": 2,
      "formatter": "language_server"
    },
    "Python": {
      "tab_size": 4,
      "formatter": "language_server",
      "language_servers": [
        "ty",
        "!basedpyright"
        // "..."
      ]
    },
    "Rust": {
      "tab_size": 4,
      "formatter": "language_server"
    },
    "JavaScript": {
      "tab_size": 2,
      "formatter": {
        "external": {
          "command": "oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "TypeScript": {
      "tab_size": 2,
      "formatter": {
        "external": {
          "command": "oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "TSX": {
      "tab_size": 2,
      "formatter": {
        "external": {
          "command": "oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "JSON": {
      "formatter": {
        "external": {
          "command": "oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "JSONC": {
      "formatter": {
        "external": {
          "command": "oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "YAML": {
      "formatter": {
        "external": {
          "command": "oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "TOML": {
      "formatter": {
        "external": {
          "command": "oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "HTML": {
      "formatter": {
        "external": {
          "command": "oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "CSS": {
      "formatter": {
        "external": {
          "command": "oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "SCSS": {
      "formatter": {
        "external": {
          "command": "oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "Markdown": {
      "formatter": {
        "external": {
          "command": "oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "GraphQL": {
      "formatter": {
        "external": {
          "command": "oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "Vue.js": {
      "formatter": {
        "external": {
          "command": "oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    }
  },
  "lsp": {
    "ols": {
      "initialization_options": {
        "enable_fake_methods": true,
        "enable_overload_resolution": true,
        "enable_inlay_hints_params": true,
        "enable_inlay_hints_default_params": true,
        "enable_inlay_hints_implicit_return": true,
        "enable_inlay_hints_optional_result": true,
        // "enable_checker_workspace_diagnostics": true
        "enable_auto_import": true,
        "enable_code_action_invert_if": true,
        "enable_semantic_tokens": true,
        "enable_snippets": true,
        "enable_comp_lit_signature_help": true,
        "enable_comp_lit_signature_help_use_docs": true
      }
    },
    "nil": {
      // or "nixd":
      "initialization_options": {
        "formatting": {
          "command": ["nixfmt"]
        }
      }
    },
    "tinymist": {
      "initialization_options": {
        "preview": {
          "background": {
            "enabled": true
          }
        }
      },
      "settings": {
        "formatterMode": "typstyle",
        "lint": {
          "enabled": true
        },
        "exportPdf": "onSave",
        "outputPath": "$root/$name"
      }
    }
  },

  "context_servers": {},

  "auto_install_extensions": {
    "nix": true,
    "html": true,
    "catppuccin": true,
    "toml": true,
    "dockerfile": true,
    "latex": true,
    "sql": true,
    "cargo-appraiser": true,
    "crates-lsp": true,
    "tsgo": true,
    "wakatime": true,
    "ron": true,
    "hyprlang": true
  }

  // "log": {
  //   "gpui_wgpu": "debug",
  //   "gpui_linux": "debug",
  //   "wgpu_hal": "debug",
  //   "project": "debug",
  //   "lsp": "debug",
  //   "language": "debug",
  //   "fs": "debug"
  // },
  // "instrumentation": {
  //   "performance_profiler": {
  //     "enabled": true
  //   }
  // }
}
